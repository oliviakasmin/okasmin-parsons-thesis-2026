{
  "name": "okasmin-parsons-thesis-2026",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:py": "python3 -m ruff check pipeline hf_space",
    "lint:py:fix": "python3 -m ruff check pipeline hf_space --fix",
    "format": "prettier \"app/**/*.{ts,tsx,css,html}\" \"*.{js,ts,json}\" --check",
    "format:fix": "prettier \"app/**/*.{ts,tsx,css,html}\" \"*.{js,ts,json}\" --write",
    "format:py": "python3 -m ruff format pipeline hf_space --check",
    "format:py:fix": "python3 -m ruff format pipeline hf_space",
    "count:objects": "python3 -m pipeline.utils",
    "typecheck": "tsc -b",
    "check:commit": "npm run format && npm run format:py && npm run lint && npm run lint:py && npm run typecheck && npm run build"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.3"
  }
}
