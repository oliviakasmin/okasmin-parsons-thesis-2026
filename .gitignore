# ─────────────────────────────────────────────
# Environment Variables
# ─────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────
# Node / TypeScript
# ─────────────────────────────────────────────
node_modules/
dist/
build/
.cache/
coverage/
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
*.log

# Netlify local
.netlify/

# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# ─────────────────────────────────────────────
# Large Local Data (Pipeline Outputs)
# ─────────────────────────────────────────────
data/raw/
data/derived/
data/published/
pipeline/outputs/

# ─────────────────────────────────────────────
# Ignore ALL images by default
# ─────────────────────────────────────────────
*.png
*.jpg
*.jpeg
*.webp
*.tif
*.tiff
*.gif
*.bmp

# ─────────────────────────────────────────────
# Re-allow ONLY deployable thumbnails
# ─────────────────────────────────────────────
!app/
!app/public/
!app/public/assets/
!app/public/assets/thumbs/
!app/public/assets/thumbs/**

# ─────────────────────────────────────────────
# Hugging Face Space runtime artifacts
# ─────────────────────────────────────────────
hf_space/.gradio/
hf_space/tmp/
hf_space/cache/
hf_space/*.pt
hf_space/*.bin
hf_space/*.ckpt
hf_space/*.safetensors

# ─────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────
# IDE
# ─────────────────────────────────────────────
.vscode/
.idea/

# ─────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────
*.swp
*.swo
*.bak